# ─── Required: Notion ───
# Get your integration token at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxx

# These are auto-generated by `npm run setup`. Don't fill manually.
NOTION_KICKSTARTER_DB_ID=
NOTION_COMPANY_ENRICHED_DB_ID=
NOTION_PEOPLE_ENRICHED_DB_ID=

# ─── Required: Apollo ───
# Sign up at https://app.apollo.io/ (Basic plan needed for People Search)
APOLLO_API_KEY=xxx

# ─── Required: OpenAI ───
# Get your key at https://platform.openai.com/api-keys
# GPT 5.4 is used for all AI decisions. GPT-4o works as a cheaper alternative.
OPENAI_API_KEY_PODSQUE=xxx

# ─── Required: Brave Search ───
# Get your key at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=xxx

# ─── Optional: Email verification (Stage 3) ───
EMAILAPI_APP_DOMAIN=
EMAILAPI_AUTH_KEY=
EMAILAPI_AUTH_SECRET=

# ─── Optional: Legacy ───
PROXYCURL_API_KEY=

# ─── Optional: Shared secrets file ───
SECRETS_ENV_PATH=~/.config/env-variables/secrets.env
